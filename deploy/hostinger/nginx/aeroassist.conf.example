# Host-level nginx reverse proxy for AeroAssist AgencyOS.
# Replace agencyos.example.com and certificate paths before enabling.
#
# Production modes:
# 1. Recommended TLS mode:
#    - Set FRONTEND_HTTP_PORT=127.0.0.1:8080 in .env.production.
#    - Run docker compose so the frontend container listens only on localhost:8080.
#    - Install this file under /etc/nginx/sites-available/aeroassist.conf.
#    - Let host nginx own ports 80 and 443.
# 2. Simpler direct-container mode:
#    - Set FRONTEND_HTTP_PORT=80 and skip host nginx/TLS.
#    - The frontend container serves HTTP directly and proxies /api internally.

server {
    listen 80;
    server_name agencyos.example.com www.agencyos.example.com;

    # Application telemetry owns privacy-safe request diagnostics. Enable a host
    # access log only after defining an explicit IP treatment and retention policy.
    access_log off;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name agencyos.example.com www.agencyos.example.com;

    access_log off;

    ssl_certificate /etc/letsencrypt/live/agencyos.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/agencyos.example.com/privkey.pem;

    client_max_body_size 10m;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Request-ID $request_id;
        proxy_set_header X-Correlation-ID $request_id;
        proxy_read_timeout 60s;
    }

    # Optional direct API route. The frontend container already proxies /api to the
    # backend service, so this block is useful only if backend port 8000 is bound
    # to localhost through a compose override.
    # location /api/ {
    #     proxy_pass http://127.0.0.1:8000/api/;
    #     proxy_http_version 1.1;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto https;
    #     proxy_set_header X-Request-ID $request_id;
    #     proxy_set_header X-Correlation-ID $request_id;
    #     proxy_read_timeout 60s;
    # }
}
