# Copy these values into your VPS environment manager, not into a committed .env file.
APP_ENV=production
AEROASSIST_DB_MODE=mongo
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=aeroassist_agencyos
DEMO_AUTH_ENABLED=false
SEED_ON_STARTUP=false
SEED_ENDPOINT_ENABLED=false
AUTH_TOKEN_SECRET=replace-with-a-long-random-production-secret
TOKEN_EXPIRY_MINUTES=720
INVITATION_EXPIRY_HOURS=72
PASSWORD_RESET_EXPIRY_HOURS=2
DOCUMENT_EXPORT_STORAGE_DIR=/var/lib/aeroassist/document_exports
CORS_ALLOWED_ORIGINS=https://agencyos.example.com
LOG_LEVEL=INFO
FRONTEND_URL=https://agencyos.example.com
PUBLIC_APP_URL=https://agencyos.example.com

# Store real SMTP passwords only in environment variables.
# Agency email settings should reference this as env:AEROASSIST_SMTP_PASSWORD.
# Leave SMTP_SECRET_REFS blank until agency SMTP mode is configured.
AEROASSIST_SMTP_PASSWORD=
SMTP_SECRET_REFS=

# For production frontend builds, set this to the backend origin if API and frontend
# are served from different origins. Leave blank when frontend nginx proxies /api
# to the backend service in docker-compose.production.yml.
VITE_API_BASE_URL=
VITE_APP_ENV=production
# Direct container mode can use 80. Host-level nginx/TLS mode should bind locally.
FRONTEND_HTTP_PORT=127.0.0.1:8080
