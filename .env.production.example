# Copy these values into your VPS environment manager, not into a committed .env file.
APP_ENV=production
AEROASSIST_DB_MODE=mongo
# Complete the existing-volume migration runbook before enabling this on an established VPS.
MONGO_AUTHENTICATION_ENABLED=true
MONGO_INITDB_ROOT_USERNAME=aeroassist_admin
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-long-random-mongodb-root-password
MONGO_APP_USERNAME=aeroassist_app
MONGO_APP_PASSWORD=replace-with-a-long-random-mongodb-app-password
MONGO_AUTH_SOURCE=admin
MONGO_DATABASE=aeroassist_agencyos
MONGO_HOST=mongo
MONGO_PORT=27017
# Optional explicit authenticated URI override. Leave blank to construct it safely from app credentials.
MONGODB_URL=
MONGODB_DATABASE=aeroassist_agencyos
BACKUP_ROOT=/var/backups/aeroassist
BACKUP_RETENTION_DAYS=30
BACKUP_MINIMUM_COUNT=7
BACKUP_ENVIRONMENT_LABEL=production
DEMO_AUTH_ENABLED=false
SEED_ON_STARTUP=false
SEED_ENDPOINT_ENABLED=false
AUTH_TOKEN_SECRET=replace-with-a-long-random-production-secret
TOKEN_EXPIRY_MINUTES=720
TOKEN_CLOCK_SKEW_SECONDS=30
TOKEN_REFRESH_POLICY=disabled
TOKEN_REFRESH_WINDOW_MINUTES=60
LOGIN_THROTTLE_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_SECONDS=900
LOGIN_FAILURE_RESET_SECONDS=900
LOGIN_BACKOFF_BASE_SECONDS=0.1
LOGIN_BACKOFF_MAX_SECONDS=2.0
INVITATION_EXPIRY_HOURS=72
PASSWORD_RESET_EXPIRY_HOURS=2
DOCUMENT_EXPORT_STORAGE_DIR=/var/lib/aeroassist/document_exports
CORS_ALLOWED_ORIGINS=https://agencyos.example.com
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=(), usb=()
SECURITY_CROSS_ORIGIN_RESOURCE_POLICY=same-site
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURITY_CROSS_ORIGIN_EMBEDDER_POLICY=unsafe-none
# Leave blank to use the generated policy. Self-host docs assets before removing Swagger CDN exceptions.
SECURITY_CONTENT_SECURITY_POLICY=
READINESS_PUBLIC_MODE=summary
READINESS_AUTHENTICATED_DETAIL_ENABLED=true
READINESS_INTERNAL_ENABLED=false
# Required (24+ characters) only when production internal readiness is explicitly enabled.
READINESS_INTERNAL_KEY=
QUERY_DEFAULT_LIMIT=50
QUERY_MAXIMUM_LIMIT=250
QUERY_SLOW_THRESHOLD_MS=250
QUERY_DIAGNOSTICS_ENABLED=true
READINESS_DATABASE_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO
FRONTEND_URL=https://agencyos.example.com
PUBLIC_APP_URL=https://agencyos.example.com

# Store real SMTP passwords only in environment variables.
# Agency email settings should reference this as env:AEROASSIST_SMTP_PASSWORD.
# Leave SMTP_SECRET_REFS blank until agency SMTP mode is configured.
AEROASSIST_SMTP_PASSWORD=
SMTP_SECRET_REFS=

# For production frontend builds, set this to the backend origin if API and frontend
# are served from different origins. Leave blank when frontend nginx proxies /api
# to the backend service in docker-compose.production.yml.
VITE_API_BASE_URL=
VITE_APP_ENV=production
# Direct container mode can use 80. Host-level nginx/TLS mode should bind locally.
FRONTEND_HTTP_PORT=127.0.0.1:8080
