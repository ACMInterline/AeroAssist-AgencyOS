# Durable production-like mode is MongoDB. Memory is for local demo/dev only.
APP_ENV=development
AEROASSIST_DB_MODE=memory
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=aeroassist_agencyos
DEMO_AUTH_ENABLED=true
SEED_ON_STARTUP=true
SEED_ENDPOINT_ENABLED=true
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
TOKEN_EXPIRY_MINUTES=720
TOKEN_CLOCK_SKEW_SECONDS=30
TOKEN_REFRESH_POLICY=disabled
TOKEN_REFRESH_WINDOW_MINUTES=60
LOGIN_THROTTLE_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_SECONDS=900
LOGIN_FAILURE_RESET_SECONDS=900
LOGIN_BACKOFF_BASE_SECONDS=0.1
LOGIN_BACKOFF_MAX_SECONDS=2.0
INVITATION_EXPIRY_HOURS=72
PASSWORD_RESET_EXPIRY_HOURS=2
DOCUMENT_EXPORT_STORAGE_DIR=.local/document_exports
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=(), usb=()
SECURITY_CROSS_ORIGIN_RESOURCE_POLICY=same-site
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURITY_CROSS_ORIGIN_EMBEDDER_POLICY=unsafe-none
# Optional full CSP override. The generated default supports Vite origins and FastAPI Swagger assets.
SECURITY_CONTENT_SECURITY_POLICY=
READINESS_PUBLIC_MODE=detailed
READINESS_AUTHENTICATED_DETAIL_ENABLED=true
READINESS_INTERNAL_ENABLED=true
READINESS_INTERNAL_KEY=
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
# SMTP passwords are resolved only through env:VARIABLE_NAME secret references stored in agency email settings.
# Example agency setting value: smtp_password_secret_ref=env:AGENCY_SMTP_PASSWORD
AGENCY_SMTP_PASSWORD=
# Optional comma-separated refs for backend/scripts/check_production_readiness.py; values are never printed.
SMTP_SECRET_REFS=env:AGENCY_SMTP_PASSWORD
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
